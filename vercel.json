{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/blipproxy.js": {
      "maxDuration": 15
    },
    "api/blipauth/status.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/cpproxy/:path*",
      "destination": "https://pocs.demo.amagi.tv/:path*"
    },
    {
      "source": "/blipproxy/:path*",
      "destination": "/api/blipproxy?p=/:path*"
    },
    {
      "source": "/blipauth/status",
      "destination": "/api/blipauth/status"
    },
    {
      "source": "/janusproxy/:path*",
      "destination": "https://pocs-trex.demo.amagi.tv/:path*"
    }
  ]
}
